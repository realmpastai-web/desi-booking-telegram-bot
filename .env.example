# Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Instamojo Configuration (for card/netbanking payments)
INSTAMOJO_API_KEY=your_instamojo_api_key
INSTAMOJO_AUTH_TOKEN=your_instamojo_auth_token
INSTAMOJO_SALT=your_webhook_salt_for_verification

# Admin Configuration
ADMIN_USER_ID=your_telegram_user_id

# Database
DB_PATH=./data/bookings.db

# Payment Settings
UPI_ID=yourname@upi
UPI_NAME=Your Business Name

# Feature Flags
ENABLE_INSTAMOJO=true
ENABLE_REMINDERS=true
